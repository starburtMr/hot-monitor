# 数据库
DATABASE_URL="file:./dev.db"

# 服务器配置
PORT=3001
CLIENT_URL=http://localhost:5173

# AI 提供商
# 可选值：
# - openrouter：默认，兼容原有 OPENROUTER_API_KEY 配置
# - minimax：MiniMax Token Plan / OpenAI 兼容接口
# - openai-compatible：任意 OpenAI 兼容服务，需填写 base url、api key、model
AI_PROVIDER=openrouter

# OpenRouter AI（AI_PROVIDER=openrouter）
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-v3.2

# MiniMax Token Plan（AI_PROVIDER=minimax）
# Token Plan API Key 与按量计费 API Key 不可混用
MINIMAX_API_KEY=your_minimax_token_plan_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7

# 通用 OpenAI 兼容接口（AI_PROVIDER=openai-compatible）
OPENAI_COMPATIBLE_BASE_URL=https://your-openai-compatible-host/v1
OPENAI_COMPATIBLE_API_KEY=your_openai_compatible_api_key_here
OPENAI_COMPATIBLE_MODEL=your-model-name

# Twitter API (twitterapi.io)
TWITTER_API_KEY=your_twitter_api_key_here

# 邮件通知 (可选)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
NOTIFY_EMAIL=notify_to@example.com
